<% include _ejs-mate-compat %>
<% layout('layout') -%>

<section style="display:grid;gap:1rem">
	<h1>Welcome to the Resource Library</h1>
	<p>Browse curated articles, books, videos, and more. Create an account to save your favorites and manage your profile.</p>
	<div style="display:flex;gap:.75rem;flex-wrap:wrap">
		<a class="btn" href="/resources">Browse Resources</a>
		<% if (!currentUser) { %>
			<a class="btn secondary" href="/auth/register">Create Account</a>
		<% } %>
	</div>
</section>

